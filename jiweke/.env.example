# Jiweke - Environment Variables Example
# Copy this file to .env and fill in your actual API keys and secrets.

# Flask Application Config
FLASK_SECRET_KEY="replace-this-with-a-secure-random-key"
DEBUG=True
DATABASE_URL="sqlite:///jiweke.db"

# WhatsApp Business Cloud API Configuration
# Get these credentials from your Meta Developers Dashboard: developers.facebook.com
WHATSAPP_TOKEN="your-whatsapp-access-token-here"
WHATSAPP_PHONE_NUMBER_ID="your-whatsapp-phone-number-id"
WHATSAPP_VERIFY_TOKEN="jiweke-verify-token-2024"

# Anthropic Claude API Configuration
# Get your API key from the Anthropic Console: console.anthropic.com
ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# M-Pesa Daraja API - Phase 2 (Scaffolded Integration)
MPESA_CONSUMER_KEY="todo"
MPESA_CONSUMER_SECRET="todo"
MPESA_SHORTCODE="todo"
MPESA_PASSKEY="todo"
